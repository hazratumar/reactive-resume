    "ollama-ai-provider-v2": "^3.5.1",
    "react": "^19.2.7",
    "resumable-stream": "^2.2.12",
    "sharp": "^0.34.5",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@resume-builder/config": "workspace:*",
