    "@aws-sdk/client-s3": "^3.1063.0",
    "@orpc/client": "^1.14.5",
    "@orpc/experimental-ratelimit": "^1.14.5",
    "@orpc/server": "^1.14.5",
    "@resume-builder/ai": "workspace:*",
    "@resume-builder/auth": "workspace:*",
    "@resume-builder/db": "workspace:*",
    "@resume-builder/env": "workspace:*",
    "@resume-builder/pdf": "workspace:*",
    "@resume-builder/resume": "workspace:*",
    "@resume-builder/schema": "workspace:*",
